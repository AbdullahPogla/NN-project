   "id": "fe2c882a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =========================================\n",
    "# 12. Visualization\n",
    "# =========================================\n",
    "plt.figure(figsize=(14, 6))\n",
    "\n",
    "# Loss Curves\n",
    "plt.subplot(1, 2, 1)\n",
    "\n",
    "plt.plot(history['train_loss'], label='Training Loss')\n",
    "\n",
    "plt.plot(history['val_loss'], label='Validation Loss (MSE)')\n",
    "\n",
    "plt.title('Loss Curves (ELU + BatchNorm)')\n",
    "\n",
    "plt.xlabel('Epochs')\n",
    "\n",
    "plt.legend()\n",
    "\n",
    "# R2 Curve\n",
    "plt.subplot(1, 2, 2)\n",
