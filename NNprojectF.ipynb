    "    label='Target 0.6'\n",
    ")\n",
    "\n",
    "plt.title('R2 Accuracy Improvement')\n",
    "\n",
    "plt.xlabel('Epochs')\n",
    "\n",
    "plt.legend()\n",
    "\n",
    "plt.show()"
   ]
  }
